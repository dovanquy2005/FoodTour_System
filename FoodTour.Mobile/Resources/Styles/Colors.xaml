<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ════════════════ WARM LIGHT PALETTE ════════════════ -->
    <!-- Primary accent — warm terracotta orange -->
    <Color x:Key="Primary">#E8672A</Color>
    <Color x:Key="PrimaryDark">#C85520</Color>
    <Color x:Key="PrimaryLight">#F4A574</Color>

    <!-- Secondary — soft peach -->
    <Color x:Key="Secondary">#FFF0E6</Color>
    <Color x:Key="SecondaryDarkText">#C85520</Color>
    <Color x:Key="Tertiary">#D4A574</Color>

    <!-- Neutral palette -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- Backgrounds -->
    <Color x:Key="Background">#FBF7F2</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceWarm">#FFF8F2</Color>
    <Color x:Key="CardBorder">#F0E8E0</Color>

    <!-- Text colors -->
    <Color x:Key="TextPrimary">#2D1F14</Color>
    <Color x:Key="TextSecondary">#8C7B6B</Color>
    <Color x:Key="TextTertiary">#B5A899</Color>

    <!-- Semantic colors -->
    <Color x:Key="Success">#5DAA68</Color>
    <Color x:Key="Error">#D94F4F</Color>
    <Color x:Key="Warning">#E8A838</Color>
    <Color x:Key="Info">#5B8FD4</Color>

    <!-- Grays -->
    <Color x:Key="Gray100">#F5F0EB</Color>
    <Color x:Key="Gray200">#E8E0D8</Color>
    <Color x:Key="Gray300">#D4C8BC</Color>
    <Color x:Key="Gray400">#B5A899</Color>
    <Color x:Key="Gray500">#8C7B6B</Color>
    <Color x:Key="Gray600">#6B5D50</Color>
    <Color x:Key="Gray900">#2D1F14</Color>
    <Color x:Key="Gray950">#1A1008</Color>

    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <!-- ════════════════ BRUSHES ════════════════ -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>