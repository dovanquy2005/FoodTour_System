<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodTour.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FoodTour.Mobile.Views"
    xmlns:ext="clr-namespace:FoodTour.Mobile.Extensions"
    Shell.NavBarIsVisible="False"
    Shell.FlyoutBehavior="Disabled">
	<!-- ═══════ RESOURCES & TEMPLATES ═══════ -->
	<Shell.Resources>
		<ResourceDictionary>
			<Style x:Key="BaseStyle" TargetType="Element">
				<Setter Property="Shell.BackgroundColor" Value="{StaticResource Background}" />
				<Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}" />
				<Setter Property="Shell.UnselectedColor" Value="{StaticResource TextTertiary}" />
				<Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource Surface}" />
				<Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
				<Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextTertiary}" />
			</Style>
			<Style TargetType="TabBar" BasedOn="{StaticResource BaseStyle}" />
		</ResourceDictionary>
	</Shell.Resources>

	<Shell.TitleView>
		<HorizontalStackLayout x:Name="StatusIndicatorContainer" 
							   HorizontalOptions="End" 
							   VerticalOptions="Center" 
							   Margin="0,0,15,0" 
							   Spacing="6"
							   IsVisible="False">
			<Label x:Name="StatusIcon" 
				   Text="☁️" 
				   FontSize="20" 
				   VerticalOptions="Center"/>
			<Label x:Name="StatusText" 
				   Text="Offline Mode" 
				   TextColor="{StaticResource TextSecondary}" 
				   FontSize="12" 
				   FontAttributes="Bold" 
				   VerticalOptions="Center"/>
		</HorizontalStackLayout>
	</Shell.TitleView>

	<!-- Trang khởi động -->
	<ShellContent 
		Route="LoadingPage" 
		ContentTemplate="{DataTemplate views:LoadingPage}" 
		Shell.TabBarIsVisible="False" 
		Shell.NavBarIsVisible="False" />

	<TabBar Route="MainTabs">
		<Tab Title="{ext:Translate Tab_Explore}" Icon="explore.png">
			<ShellContent Route="ExplorePage" ContentTemplate="{DataTemplate views:ExplorePage}" />
		</Tab>

		<Tab Title="{ext:Translate Tab_Map}" Icon="map.png">
			<ShellContent Route="MapPage" ContentTemplate="{DataTemplate views:MapPage}" />
		</Tab>

		<Tab Title="{ext:Translate Tab_Scan}" Icon="qr_code_scanner.png">
			<ShellContent Route="ScanPage" ContentTemplate="{DataTemplate views:ScanPage}" />
		</Tab>

		<Tab Title="{ext:Translate Tab_Alerts}" Icon="notifications.png">
			<ShellContent Route="AlertsPage" ContentTemplate="{DataTemplate views:AlertsPage}" />
		</Tab>

		<Tab Title="{ext:Translate Tab_Settings}" Icon="settings.png">
			<ShellContent Route="SettingsPage" ContentTemplate="{DataTemplate views:SettingsPage}" />
		</Tab>
	</TabBar>

</Shell>