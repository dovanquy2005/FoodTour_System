<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ext="clr-namespace:FoodTour.Mobile.Extensions"
             xmlns:viewmodels="clr-namespace:FoodTour.Mobile.ViewModels"
             xmlns:models="clr-namespace:FoodTour.Mobile.Models"
             x:Class="FoodTour.Mobile.Views.LanguageSelectionPage"
             x:DataType="viewmodels:SettingsViewModel"
             Title="{ext:Translate Settings_SelectLanguage}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            
            <Label Text="{ext:Translate Settings_SelectLanguage}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="0, 10, 0, 20" />

            <CollectionView ItemsSource="{Binding Languages}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedLanguageItem, Mode=TwoWay}"
                            SelectionChangedCommand="{Binding LanguageSelectedCommand}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LanguageOption">
                        <Border BackgroundColor="{StaticResource Surface}"
                                StrokeShape="RoundRectangle 12"
                                Stroke="{StaticResource CardBorder}"
                                StrokeThickness="1"
                                Margin="0, 0, 0, 12"
                                Padding="16, 12"
                                Shadow="{Shadow Radius=4, Opacity=0.05, Offset='0,1'}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CommonStates">
                                    <VisualState Name="Normal" />
                                    <VisualState Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#F0F8FF" />
                                            <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <!-- Country Emoji / Icon -->
                                <Label Grid.Column="0" 
                                       Text="{Binding FlagIcon}" 
                                       FontSize="24" 
                                       VerticalOptions="Center" 
                                       Margin="0,0,15,0" />

                                <!-- Language Name -->
                                <Label Grid.Column="1" 
                                       Text="{Binding DisplayName}" 
                                       FontSize="16" 
                                       TextColor="{StaticResource TextPrimary}" 
                                       VerticalOptions="Center" />

                                <!-- Checkmark for selected -->
                                <Label Grid.Column="2" 
                                       Text="✓" 
                                       FontSize="20" 
                                       TextColor="{StaticResource Primary}" 
                                       VerticalOptions="Center" 
                                       IsVisible="{Binding IsSelected}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
