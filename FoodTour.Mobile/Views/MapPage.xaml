<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="FoodTour.Mobile.Views.MapPage"
             Title="Bản Đồ FoodTour">

	<Grid>
		<maps:Map x:Name="TourMap" IsShowingUser="False" MapType="Street" ItemsSource="{Binding Pois}">
			<maps:Map.ItemTemplate>
				<DataTemplate>
					<maps:Pin Label="{Binding Name}" Address="{Binding Address}" Type="Place" Location="{Binding Location}" />
				</DataTemplate>
			</maps:Map.ItemTemplate>
		</maps:Map>

		<Grid VerticalOptions="End" Margin="15,0,15,30" IsVisible="{Binding IsPlayerVisible}">

			<Frame IsVisible="{Binding IsPlayerExpanded}"
                   CornerRadius="15" BackgroundColor="#222" Padding="15,10" HasShadow="True">

				<Grid ColumnDefinitions="*, 40, 40" ColumnSpacing="5">
					<VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
						<Label Text="{Binding CurrentShopName}" TextColor="White" FontAttributes="Bold" LineBreakMode="TailTruncation" FontSize="15"/>
						<Label Text="{Binding PlayerStatus}" TextColor="#AAA" FontSize="12"/>
					</VerticalStackLayout>

					<Button Grid.Column="1" Text="{Binding PlayIcon}" Command="{Binding PlayPauseCommand}"
                            BackgroundColor="Transparent" TextColor="#FF5722" FontSize="24" Padding="0"/>

					<Button Grid.Column="2" Text="＜" Command="{Binding ToggleExpandCommand}"
                            BackgroundColor="#333" TextColor="White"
                            FontSize="20" FontAttributes="Bold"
                            HeightRequest="30" WidthRequest="30" CornerRadius="15"
                            VerticalOptions="Center" Padding="0"/>
				</Grid>
			</Frame>

			<Frame IsVisible="{Binding IsPlayerCollapsed}"
                   HorizontalOptions="Start" VerticalOptions="End"
                   HeightRequest="60" WidthRequest="60" CornerRadius="30"
                   BackgroundColor="#FF5722" Padding="0" HasShadow="True">

				<Frame.GestureRecognizers>
					<TapGestureRecognizer Command="{Binding ToggleExpandCommand}"/>
				</Frame.GestureRecognizers>

				<Label Text="🎵" TextColor="White" FontSize="24"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
			</Frame>

		</Grid>
	</Grid>
</ContentPage>