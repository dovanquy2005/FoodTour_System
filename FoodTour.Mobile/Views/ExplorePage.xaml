<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodTour.Mobile.Models"
             xmlns:viewmodels="clr-namespace:FoodTour.Mobile.ViewModels"
             xmlns:ext="clr-namespace:FoodTour.Mobile.Extensions"
             x:Class="FoodTour.Mobile.Views.ExplorePage"
             x:DataType="viewmodels:ExploreViewModel"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="False">

	<Grid RowDefinitions="Auto, Auto, *" Margin="20, 15, 20, 0">

		<!-- ═══════ HEADER ═══════ -->
		<VerticalStackLayout Grid.Row="0" Margin="0,12,0,18" HorizontalOptions="Center" Spacing="2">
			<!-- Offline Icon Badge -->
			<Image Source="offline.png" 
				   WidthRequest="40" 
				   HeightRequest="40" 
				   IsVisible="{Binding IsOffline}" 
				   HorizontalOptions="Center"
				   Margin="0,0,0,5"
				   Aspect="AspectFit"/>
			
			<Label Text="{ext:Translate Explore_Title1}"
			       TextColor="{StaticResource TextPrimary}"
			       FontSize="22"
			       FontAttributes="Bold"
			       HorizontalOptions="Center"/>
			<Label Text="{ext:Translate Explore_Title2}"
			       TextColor="{StaticResource TextSecondary}"
			       FontSize="13"
			       HorizontalOptions="Center"/>
		</VerticalStackLayout>

		<!-- ═══════ THANH TÌM KIẾM ═══════ -->
		<Border Grid.Row="1"
		        BackgroundColor="{StaticResource Surface}"
		        StrokeShape="RoundRectangle 16"
		        Stroke="{StaticResource CardBorder}"
		        StrokeThickness="1"
		        HeightRequest="48"
		        Margin="0,0,0,18"
		        Shadow="{Shadow Radius=6, Opacity=0.06, Offset='0,2'}">
			<Grid ColumnDefinitions="Auto, *" Margin="14,0,14,0">
				<Image Grid.Column="0"
				       Source="search.png"
				       WidthRequest="20" HeightRequest="20"
				       VerticalOptions="Center"
				       Margin="0,0,10,0"
				       Opacity="0.45"/>
				<Entry Grid.Column="1"
				       Placeholder="{ext:Translate Explore_SearchPlaceholder}"
				       PlaceholderColor="{StaticResource TextTertiary}"
				       TextColor="{StaticResource TextPrimary}"
				       BackgroundColor="Transparent"
				       VerticalOptions="Center"
				       FontSize="15"/>
			</Grid>
		</Border>

		<!-- ═══════ DANH SÁCH QUÁN ĂN ═══════ -->
		<CollectionView Grid.Row="2"
		                ItemsSource="{Binding Shops}"
		                SelectionMode="None">
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="models:ShopModel">
					<Border BackgroundColor="{StaticResource Surface}"
					        StrokeShape="RoundRectangle 16"
					        Stroke="{StaticResource CardBorder}"
					        StrokeThickness="1"
					        Margin="0,0,0,14"
					        Shadow="{Shadow Radius=8, Opacity=0.06, Offset='0,3'}">
						<Grid RowDefinitions="175, Auto">

							<!-- Ảnh quán + bo góc trên (tap = mở chi tiết) -->
							<Border Grid.Row="0"
							        StrokeThickness="0"
							        StrokeShape="RoundRectangle 16,16,0,0"
							        BackgroundColor="{StaticResource Gray100}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnShopCardTapped" CommandParameter="{Binding .}" />
								</Border.GestureRecognizers>
								<Image Source="{Binding ImageUrl}" Aspect="AspectFill" InputTransparent="True"/>
							</Border>

							<!-- Badge rating -->
							<Border Grid.Row="0"
							        BackgroundColor="#E6FFFFFF"
							        StrokeShape="RoundRectangle 10"
							        StrokeThickness="0"
							        HorizontalOptions="End"
							        VerticalOptions="Start"
							        Margin="0,10,10,0"
							        Padding="9,5"
							        InputTransparent="True">
								<HorizontalStackLayout Spacing="4" VerticalOptions="Center">
									<Label Text="★" TextColor="{StaticResource Primary}" FontSize="13" VerticalOptions="Center"/>
									<Label Text="{Binding Rating}" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
								</HorizontalStackLayout>
							</Border>

							<!-- Thông tin quán + Nút dẫn đường -->
							<Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="14,12,14,14">
								<!-- Tên + Địa chỉ (tap = mở chi tiết) -->
								<VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
									<VerticalStackLayout.GestureRecognizers>
										<TapGestureRecognizer Tapped="OnShopCardTapped" CommandParameter="{Binding .}" />
									</VerticalStackLayout.GestureRecognizers>
									<Label Text="{Binding Name}"
									       TextColor="{StaticResource TextPrimary}"
									       FontSize="17"
									       FontAttributes="Bold"
									       LineBreakMode="TailTruncation"
									       MaxLines="1"/>
									<Label Text="{Binding Address}"
									       TextColor="{StaticResource TextSecondary}"
									       FontSize="13"
									       LineBreakMode="TailTruncation"
									       MaxLines="1"/>
								</VerticalStackLayout>

								<!-- Nút dẫn đường (dùng Image + Tap thay vì ImageButton) -->
								<Border Grid.Column="1"
								        StrokeThickness="0"
								        WidthRequest="44" 
								        HeightRequest="44"
								        VerticalOptions="Center"
								        Margin="8,0,0,0"
								        Padding="4"
								        BackgroundColor="Transparent">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="OnNavigateToShopTapped" CommandParameter="{Binding .}" />
									</Border.GestureRecognizers>
									<Image Source="customer_journey.png" 
									       Aspect="AspectFit"
									       InputTransparent="True"/>
								</Border>
							</Grid>

						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

	</Grid>
</ContentPage>