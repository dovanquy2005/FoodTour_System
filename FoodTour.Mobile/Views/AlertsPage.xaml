<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodTour.Mobile.Views.AlertsPage"
             BackgroundColor="#120E0E"
             NavigationPage.HasNavigationBar="False">
    <Grid RowDefinitions="Auto, *" Margin="20, 25, 20, 0">
        <Label Grid.Row="0" Text="Thông báo" TextColor="White" FontSize="24" FontAttributes="Bold" Margin="0,0,0,20" />
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="15">
                <Border BackgroundColor="#1A1A1A" StrokeShape="RoundRectangle 15" StrokeThickness="0" Padding="15">
                    <Grid ColumnDefinitions="Auto, *">
                        <BoxView Grid.Column="0" Color="#FF6F00" WidthRequest="10" HeightRequest="10" CornerRadius="5" VerticalOptions="Start" Margin="0,5,15,0"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Dữ liệu tuyến phố đã cập nhật" TextColor="White" FontSize="16" FontAttributes="Bold" />
                            <Label Text="Đã thêm file audio cho các quán ốc Quận 4." TextColor="#8A8A8A" FontSize="14" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>