<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ext="clr-namespace:FoodTour.Mobile.Extensions"
             x:Class="FoodTour.Mobile.Views.AlertsPage"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="False">

	<Grid RowDefinitions="Auto, *" Margin="20, 25, 20, 0">

		<!-- Header -->
		<Label Grid.Row="0"
		       Text="{ext:Translate Alert_Title}"
		       TextColor="{StaticResource TextPrimary}"
		       FontSize="24"
		       FontAttributes="Bold"
		       Margin="0,8,0,18"/>

		<ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
			<VerticalStackLayout Spacing="12">

				<!-- Notification card -->
				<Border BackgroundColor="{StaticResource Surface}"
				        StrokeShape="RoundRectangle 14"
				        Stroke="{StaticResource CardBorder}"
				        StrokeThickness="1"
				        Padding="14"
				        Shadow="{Shadow Radius=6, Opacity=0.05, Offset='0,2'}">
					<Grid ColumnDefinitions="Auto, *" ColumnSpacing="14">
						<!-- Orange dot -->
						<Border Grid.Column="0"
						        BackgroundColor="{StaticResource Primary}"
						        StrokeThickness="0"
						        WidthRequest="10" HeightRequest="10"
						        StrokeShape="RoundRectangle 5"
						        VerticalOptions="Start"
						        Margin="0,6,0,0"/>
						<VerticalStackLayout Grid.Column="1" Spacing="4">
							<Label Text="{ext:Translate Alert_SampleTitle}"
							       TextColor="{StaticResource TextPrimary}"
							       FontSize="15"
							       FontAttributes="Bold"/>
							<Label Text="{ext:Translate Alert_SampleMessage}"
							       TextColor="{StaticResource TextSecondary}"
							       FontSize="13"
							       LineHeight="1.2"/>
							<Label Text="{ext:Translate Alert_Today}"
							       TextColor="{StaticResource TextTertiary}"
							       FontSize="12"
							       Margin="0,2,0,0"/>
						</VerticalStackLayout>
					</Grid>
				</Border>

				<!-- Empty state placeholder -->
				<VerticalStackLayout Margin="0,30,0,0" HorizontalOptions="Center" Spacing="8">
					<Label Text="🔔" FontSize="36" HorizontalOptions="Center" Opacity="0.4"/>
					<Label Text="{ext:Translate Alert_EmptyState}"
					       TextColor="{StaticResource TextTertiary}"
					       FontSize="14"
					       HorizontalOptions="Center"/>
				</VerticalStackLayout>

			</VerticalStackLayout>
		</ScrollView>
	</Grid>
</ContentPage>