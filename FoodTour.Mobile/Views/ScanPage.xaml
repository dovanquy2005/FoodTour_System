<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ext="clr-namespace:FoodTour.Mobile.Extensions"
             x:Class="FoodTour.Mobile.Views.ScanPage"
             BackgroundColor="{StaticResource Background}"
             NavigationPage.HasNavigationBar="False">

	<Grid RowDefinitions="Auto, *, Auto" Margin="20, 40, 20, 30">

		<!-- Header -->
		<VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="4">
			<Label Text="{ext:Translate Scan_Title}"
			       TextColor="{StaticResource TextPrimary}"
			       FontSize="24"
			       FontAttributes="Bold"
			       HorizontalOptions="Center"/>
			<Label Text="{ext:Translate Scan_Subtitle}"
			       TextColor="{StaticResource TextSecondary}"
			       FontSize="13"
			       HorizontalOptions="Center"/>
		</VerticalStackLayout>

		<!-- QR Scanner Area -->
		<Grid Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center"
		      HeightRequest="260" WidthRequest="260">
			<Border BackgroundColor="{StaticResource Surface}"
			        Stroke="{StaticResource Primary}"
			        StrokeThickness="2.5"
			        StrokeShape="RoundRectangle 24"
			        StrokeDashArray="8,6"
			        Shadow="{Shadow Radius=12, Opacity=0.08, Offset='0,4'}">
				<VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
					<Label Text="📷" FontSize="40" HorizontalOptions="Center"/>
					<Label Text="{ext:Translate Scan_CameraInstruction}"
					       TextColor="{StaticResource TextSecondary}"
					       FontSize="14"
					       HorizontalOptions="Center"/>
				</VerticalStackLayout>
			</Border>
		</Grid>

		<!-- Footer instruction -->
		<Border Grid.Row="2"
		        BackgroundColor="{StaticResource SurfaceWarm}"
		        StrokeShape="RoundRectangle 14"
		        StrokeThickness="0"
		        Padding="16,12">
			<Label Text="{ext:Translate Scan_FooterInstruction}"
			       TextColor="{StaticResource TextSecondary}"
			       FontSize="13"
			       HorizontalTextAlignment="Center"
			       LineHeight="1.3"/>
		</Border>
	</Grid>
</ContentPage>