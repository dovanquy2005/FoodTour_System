<MudNavMenu Bordered="true" Style="padding: 12px 8px;">

    <!-- Brand section -->
    <div style="text-align: center; padding: 16px 0 20px 0; margin-bottom: 8px; border-bottom: 1px solid #F0E8E0;">
        <div style="width: 56px; height: 56px; border-radius: 16px; background: linear-gradient(135deg, #E8672A, #C85520);
                    display: inline-flex; align-items: center; justify-content: center; margin-bottom: 8px;
                    box-shadow: 0 4px 12px rgba(232,103,42,0.3);">
            <MudIcon Icon="@Icons.Material.Filled.Restaurant" Style="color: white; font-size: 28px;" />
        </div>
        <MudText Typo="Typo.subtitle1" Style="font-weight: 700; color: #2D1F14;">Quản trị hệ thống</MudText>
        <MudText Typo="Typo.caption" Style="color: #8C7B6B;">Phố Vĩnh Khánh</MudText>
    </div>

    <!-- Navigation -->
    <MudText Typo="Typo.overline" Style="padding: 8px 16px 4px; color: #B5A899; letter-spacing: 1.5px; font-weight: 600;">
        TỔNG QUAN
    </MudText>
    <MudNavLink Href="/" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard"
                Style="border-radius: 10px; margin: 2px 4px;">
        Dashboard
    </MudNavLink>

    <MudText Typo="Typo.overline" Style="padding: 16px 16px 4px; color: #B5A899; letter-spacing: 1.5px; font-weight: 600;">
        QUẢN LÝ
    </MudText>
    <MudNavLink Href="/shops" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Storefront"
                Style="border-radius: 10px; margin: 2px 4px;">
        Quán ăn
    </MudNavLink>
    <MudNavLink Href="/dishes" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.RestaurantMenu"
                Style="border-radius: 10px; margin: 2px 4px;">
        Món ăn
    </MudNavLink>

    <MudText Typo="Typo.overline" Style="padding: 16px 16px 4px; color: #B5A899; letter-spacing: 1.5px; font-weight: 600;">
        HỆ THỐNG
    </MudText>
    <MudNavLink Href="#" Icon="@Icons.Material.Filled.Settings"
                Style="border-radius: 10px; margin: 2px 4px;">
        Cài đặt
    </MudNavLink>
    <MudNavLink Href="#" Icon="@Icons.Material.Filled.BarChart"
                Style="border-radius: 10px; margin: 2px 4px;">
        Thống kê
    </MudNavLink>
</MudNavMenu>
