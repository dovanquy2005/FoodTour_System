@page "/dishes"
@inject AppDbContext Db
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IWebHostEnvironment Env

<PageTitle>Món ăn — FoodTour Admin</PageTitle>

<style>
    /* Styling for MudTable Pager to match the modern application design */
    .mud-table-pagination {
        border-top: 1px solid #F0E8E0 !important;
        background-color: #FFFDF9 !important;
        padding: 8px 16px !important;
        margin: 0 !important;
    }
    .mud-table-pagination-caption, 
    .mud-table-pagination-display {
        color: #5C4A3D !important;
        font-weight: 600 !important;
        font-size: 0.95rem !important;
    }
    .mud-table-pagination-select {
        margin: 0 16px !important;
    }
    .mud-table-pagination-select .mud-input-control {
        margin: 0 !important;
    }
    .mud-table-pagination-select .mud-input {
        background: white !important;
        border-radius: 8px !important;
        border: 1px solid #E0D5CB !important;
        height: 34px !important;
        padding: 0 4px 0 12px !important;
    }
    .mud-table-pagination-select .mud-input::before,
    .mud-table-pagination-select .mud-input::after {
        display: none !important; /* Remove underline */
    }
    .mud-table-pagination-select .mud-input-slot {
        color: #E8672A !important;
        font-weight: 800 !important;
        font-size: 0.95rem !important;
        padding: 0 !important;
        margin-top: 2px !important;
    }
    .mud-table-pagination-select .mud-select-icon {
        color: #8C7B6B !important;
        margin-top: 2px !important;
    }
    .mud-table-pagination-actions .mud-icon-button {
        color: #E8672A !important;
    }
    .mud-table-pagination-actions .mud-icon-button:hover {
        background-color: #FFF0E6 !important;
    }
    .mud-table-pagination-actions .mud-icon-button.mud-disabled {
        color: #E0D5CB !important;
    }
</style>

<MudStack Spacing="4">
    <!-- ═══════ HEADER ═══════ -->
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="flex-wrap: wrap; gap: 12px;">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5" Style="font-weight: 800; color: #2D1F14;">🍲 Quản lý Món ăn</MudText>
            <MudText Typo="Typo.body2" Style="color: #8C7B6B;">Quản lý thực đơn của các quán trên phố Vĩnh Khánh</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Style="border-radius: 12px; text-transform: none; font-weight: 600; padding: 10px 24px;"
                   OnClick="OpenCreateDialog">
            Thêm món mới
        </MudButton>
    </MudStack>

    <!-- ═══════ FILTERS ═══════ -->
    <MudPaper Elevation="0" Style="padding: 16px; border-radius: 16px; border: 1px solid #F0E8E0;">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="_searchString" Placeholder="Tìm kiếm món ăn..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudSelect @bind-Value="_selectedShopId" Label="Lọc theo quán" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Clearable="true">
                    @foreach (var ShopModel in _shops)
                    {
                        <MudSelectItem T="string" Value="@ShopModel.Id">@ShopModel.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="12" md="4" Style="display: flex; align-items: center; gap: 8px;">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                    @_filteredDishes.Count() kết quả
                </MudChip>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- ═══════ DATA TABLE ═══════ -->
    <MudPaper Elevation="0" Style="border-radius: 16px; border: 1px solid #F0E8E0; overflow: hidden;">
        <MudTable Items="_filteredDishes" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm"
                  Loading="_loading" LoadingProgressColor="Color.Primary">
            <HeaderContent>
                <MudTh Style="font-weight: 700; background: #FBF7F2;">Món ăn</MudTh>
                <MudTh Style="font-weight: 700; background: #FBF7F2;">Quán</MudTh>
                <MudTh Style="font-weight: 700; background: #FBF7F2;">Giá</MudTh>
                <MudTh Style="font-weight: 700; background: #FBF7F2; text-align: center;">Hành động</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                        @if (!string.IsNullOrEmpty(context.ImageUrl) && (context.ImageUrl.Contains("/") || context.ImageUrl.StartsWith("data:image", StringComparison.OrdinalIgnoreCase)))
                        {
                            <MudAvatar Size="Size.Medium" Image="@context.ImageUrl" Style="background: transparent;" />
                        }
                        else
                        {
                            <MudAvatar Size="Size.Medium" Style="background: #FFF0E6; color: #E8672A; border-radius: 8px;">
                                <MudIcon Icon="@Icons.Material.Filled.LunchDining" />
                            </MudAvatar>
                        }
                        <MudStack Spacing="0">
                            <MudText Style="font-weight: 600; color: #2D1F14;">@context.Name</MudText>
                            <MudText Typo="Typo.caption" Style="color: #B5A899;">@(context.Id?.Length > 8 ? context.Id[..8] + "..." : context.Id ?? "")</MudText>
                        </MudStack>
                    </MudStack>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                        @(_shopNames.TryGetValue(context.ShopId ?? "", out var name) ? name : (context.ShopId?.Length > 8 ? context.ShopId[..8] : context.ShopId ?? ""))
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudText Style="font-weight: 700; color: #E8672A;">
                        @context.Price.ToString("N0")đ
                    </MudText>
                </MudTd>
                <MudTd Style="text-align: center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenEditDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => ConfirmDelete(context))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }"
                               RowsPerPageString="Số dòng mỗi trang:"
                               InfoFormat="{first_item}-{last_item} trong tổng số {all_items}" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

<!-- ═══════ SAVING OVERLAY ═══════ -->
<MudOverlay Visible="_isSaving" DarkBackground="true" Absolute="false" ZIndex="9999">
    <MudPaper Style="padding: 32px; border-radius: 24px; min-width: 300px; text-align: center; box-shadow: 0 16px 40px rgba(0,0,0,0.15); background: white;" Elevation="0">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" StrokeWidth="4" />
            <MudStack Spacing="1">
                <MudText Typo="Typo.h6" Style="font-weight: 800; color: #2D1F14;">Đang lưu thông tin món</MudText>
                <MudText Typo="Typo.body2" Style="color: #8C7B6B;">Vui lòng chờ trong giây lát...</MudText>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudOverlay>

<!-- ═══════ CREATE / EDIT DIALOG ═══════ -->
<MudDialog @bind-Visible="_dialogVisible" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@(_isEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.AddCircle)"
                     Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-weight: 700;">
                @(_isEdit ? "Chỉnh sửa món ăn" : "Thêm món ăn mới")
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudStack Spacing="3" Style="padding-top: 8px;">
                <MudTextField @bind-Value="_editDish.Name" Label="Tên món *" Variant="Variant.Outlined"
                              Required="true" RequiredError="Vui lòng nhập tên món" Immediate="true" />
                <MudSelect @bind-Value="_editDish.ShopId" Label="Quán ăn *" Variant="Variant.Outlined"
                           Required="true" RequiredError="Vui lòng chọn quán">
                    @foreach (var ShopModel in _shops)
                    {
                        <MudSelectItem T="string" Value="@ShopModel.Id">@ShopModel.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudNumericField @bind-Value="_editDish.Price" Label="Giá (VNĐ) *" Variant="Variant.Outlined"
                                 Min="0.0" Step="1000.0" Format="N0"
                                 Adornment="Adornment.End" AdornmentText="đ" Immediate="true" />
                <div style="border: 1px dashed #C85520; border-radius: 12px; padding: 16px; text-align: center; background: #FFF0E6;">
                    <MudText Typo="Typo.body2" Style="color: #E8672A; font-weight: 600; margin-bottom: 8px;">📸 Tải ảnh lên</MudText>
                    <InputFile OnChange="UploadImage" accept=".jpg,.jpeg,.png,.webp" class="form-control" style="font-size: 0.85rem;" />
                    @if (!string.IsNullOrEmpty(_editDish.ImageUrl) && (_editDish.ImageUrl.Contains("/") || _editDish.ImageUrl.StartsWith("data:image", StringComparison.OrdinalIgnoreCase)))
                    {
                        <div style="margin-top: 12px;">
                            <img src="@_editDish.ImageUrl" style="height: 100px; border-radius: 8px; object-fit: cover;" />
                        </div>
                    }
                </div>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _dialogVisible = false)" Variant="Variant.Text" Color="Color.Default"
                   Style="text-transform: none;">Hủy</MudButton>
        <MudButton OnClick="SaveDish" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!_formValid || _isSaving)"
                   Style="text-transform: none; border-radius: 10px; font-weight: 600;">
            @(_isEdit ? "Cập nhật" : "Tạo mới")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<DishModel> _dishes = new();
    private List<ShopModel> _shops = new();
    private Dictionary<string, string> _shopNames = new();
    private bool _loading = true;
    private bool _isSaving = false;
    private string _searchString = "";
    private string? _selectedShopId;

    // Dialog state
    private bool _dialogVisible;
    private bool _isEdit;
    private string _editingId = "";
    private FoodTour_WebAdmin.Api.DTOs.CreateDishRequest _editDish = new();
    private MudForm? _form;
    private bool _formValid;

    private IEnumerable<DishModel> _filteredDishes => _dishes.Where(d =>
    {
        if (!string.IsNullOrEmpty(_searchString) &&
            !d.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return false;
        if (!string.IsNullOrEmpty(_selectedShopId) && d.ShopId != _selectedShopId)
            return false;
        return true;
    });

    protected override async Task OnInitializedAsync()
    {
        var allShops = await Db.Shops.Include(s => s.ShopTranslations).AsNoTracking().ToListAsync();
        _shops = allShops.OrderBy(s => s.Name).ToList();
        _shopNames = _shops.ToDictionary(s => s.Id, s => s.Name);
        await LoadDishes();
    }

    private async Task LoadDishes()
    {
        _loading = true;
        StateHasChanged();
        var allDishes = await Db.Dishes.Include(d => d.DishTranslations).AsNoTracking().ToListAsync();
        _dishes = allDishes.OrderBy(d => d.ShopId).ThenBy(d => d.Name).ToList();
        _loading = false;
        StateHasChanged();
    }

    private void OpenCreateDialog()
    {
        _isEdit = false;
        _editingId = "";
        _editDish = new FoodTour_WebAdmin.Api.DTOs.CreateDishRequest();
        _dialogVisible = true;
    }

    private void OpenEditDialog(DishModel DishModel)
    {
        _isEdit = true;
        _editingId = DishModel.Id;
        _editDish = new FoodTour_WebAdmin.Api.DTOs.CreateDishRequest
        {
            ShopId = DishModel.ShopId,
            Name = DishModel.Name,
            Price = DishModel.Price,
            ImageUrl = DishModel.ImageUrl,
        };
        _dialogVisible = true;
    }

    private async Task SaveDish()
    {
        _isSaving = true;
        StateHasChanged();
        
        try
        {
            using var scope = Constants.ServiceProvider?.CreateScope();
            var service = scope?.ServiceProvider.GetRequiredService<FoodTour_WebAdmin.Api.Services.ManageFoodTourService>();
            
            if (service != null && !string.IsNullOrEmpty(_editDish.Name))
            {
                if (_isEdit)
                {
                    await service.UpdateDishWithTranslationAsync(_editingId, _editDish);
                    Snackbar.Add($"Đã cập nhật món \"{_editDish.Name}\"!", Severity.Success);
                }
                else
                {
                    var newDish = await service.CreateDishWithTranslationAsync(_editDish);
                    Snackbar.Add($"Đã thêm món \"{_editDish.Name}\" thành công!", Severity.Success);
                }
            }
            else
            {
                 Snackbar.Add($"Lỗi DI khi lấy ManageFoodTourService", Severity.Error);
            }
        }
        finally
        {
            _isSaving = false;
        }

        _dialogVisible = false;
        await LoadDishes();
    }

    private async Task ConfirmDelete(DishModel DishModel)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Xác nhận xóa",
            $"Bạn có chắc muốn xóa món \"{DishModel.Name}\"?",
            yesText: "Xóa", cancelText: "Hủy");

        if (result == true)
        {
            var toDelete = await Db.Dishes.FindAsync(DishModel.Id);
            if (toDelete != null)
            {
                Db.Dishes.Remove(toDelete);
                await Db.SaveChangesAsync();
            }
            Snackbar.Add($"Đã xóa món \"{DishModel.Name}\"!", Severity.Warning);
            await LoadDishes();
        }
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            var webRootPath = Env.WebRootPath ?? Path.Combine(Env.ContentRootPath, "wwwroot");
            var uploadPath = Path.Combine(webRootPath, "uploads", "dishes");
            if (!Directory.Exists(uploadPath))
                Directory.CreateDirectory(uploadPath);

            var fileName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";
            var filePath = Path.Combine(uploadPath, fileName);

            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024); // 5MB limit
            using var fs = new FileStream(filePath, FileMode.Create);
            await stream.CopyToAsync(fs);

            _editDish.ImageUrl = $"/uploads/dishes/{fileName}";
            StateHasChanged();
            Snackbar.Add("Đã tải ảnh lên thành công!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải ảnh: {ex.Message}", Severity.Error);
        }
    }
}
